.failure-circle { stroke-dasharray: 166; stroke-dashoffset: 166; stroke-wid=
th: 2; stroke-miterlimit: 10; stroke: rgb(178, 15, 3); fill: rgb(178, 15, 3=
); animation: 0.6s cubic-bezier(0.65, 0, 0.45, 1) 0s 1 normal forwards runn=
ing stroke; }

