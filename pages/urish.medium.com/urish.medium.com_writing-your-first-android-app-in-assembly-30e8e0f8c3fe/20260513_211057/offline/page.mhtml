@charset "utf-8";

@keyframes spin {=20
  100% { transform: rotate(360deg); }
}

@keyframes scale {=20
  0%, 100% { transform: none; }
  50% { transform: scale3d(1, 1, 1); }
}

@keyframes stroke {=20
  100% { stroke-dashoffset: 0; }
}

@keyframes scale-up-center {=20
  0% { transform: scale(0.01); }
  100% { transform: scale(1); }
}

@keyframes fade-in {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes fireworks {=20
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.5); opacity: 1; }
  100% { transform: scale(2); opacity: 0; }
}

@keyframes firework {=20
  0% { opacity: 0; stroke-dashoffset: 8; }
  30% { opacity: 1; }
  100% { stroke-dashoffset: -8; }
}

@keyframes unspin {=20
  40% { stroke-width: 1px; stroke-linecap: square; stroke-dashoffset: 192; =
}
  100% { stroke-width: 0; }
}

#success-i { width: 30px; height: 30px; display: flex; border-radius: 50%; =
box-shadow: rgb(34, 139, 73) 0px 0px 0px inset; fill: rgb(255, 255, 255); s=
troke: rgb(255, 255, 255); stroke-miterlimit: 10; animation: 0.3s cubic-bez=
ier(0.55, 0.085, 0.68, 0.53) 0s 1 normal both running scale-up-center; stro=
ke-width: 6px; }

#success-i .p1 { animation: 0.4s cubic-bezier(0.65, 0, 0.45, 1) 0.3s 1 norm=
al forwards running stroke; box-shadow: rgb(34, 139, 73) 0px 0px 0px inset;=
 stroke-dasharray: 242; stroke-dashoffset: 242; }

.success-circle { stroke-dashoffset: 0; stroke-width: 2; stroke-miterlimit:=
 10; stroke: rgb(34, 139, 73); fill: rgb(34, 139, 73); }

#success-pre-i { width: 30px; height: 30px; }

#success-pre-i line { stroke: rgb(34, 139, 73); animation: 0.3s ease-out 0s=
 1 normal none running firework; stroke-width: 1; stroke-dasharray: 32, 32;=
 stroke-dashoffset: -8; }

.circle { stroke-width: 3px; stroke-linecap: round; stroke: rgb(34, 139, 73=
); stroke-dasharray: 0, 100, 0; stroke-dashoffset: 200; stroke-miterlimit: =
1; stroke-linejoin: round; }

#fail-i, #fail-small-i { width: 30px; height: 30px; display: flex; border-r=
