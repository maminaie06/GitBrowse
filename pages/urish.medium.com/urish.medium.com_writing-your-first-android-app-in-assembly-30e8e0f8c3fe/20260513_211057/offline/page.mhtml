n: center bottom; }

@keyframes fade-in-animation {=20
  0% { fill: rgb(178, 15, 3); stroke: rgb(178, 15, 3); }
  100% { fill: rgb(242, 242, 242); stroke: rgb(242, 242, 242); }
}

#fail-small-i { width: 12px; height: 12px; }

